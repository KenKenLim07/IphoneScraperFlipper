SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
FB_MARKETPLACE_ILOILO_URL=https://www.facebook.com/marketplace/iloilo/search?query=iphone&sortBy=creation_time_descend

# Playwright profile/session
PLAYWRIGHT_PROFILE_DIR=.playwright_profile/facebook_personal
PLAYWRIGHT_PROFILE_ISOLATE_BY_CHANNEL=true

# Browser settings
PLAYWRIGHT_BROWSER_CHANNEL=chromium
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_EXTRA_USE_STEALTH=true

# Optional scrape controls
SCRAPE_LOG_PROGRESS=true
SCRAPE_LOG_FILE=false
SCRAPE_USE_NETWORK=false
SCRAPE_NETWORK_SAVE_RAW=false
# When true, logs GraphQL/marketplace response URLs (for debugging network extraction).
SCRAPE_NETWORK_DEBUG=false
# When true, logs ALL response URLs (very noisy).
SCRAPE_NETWORK_DEBUG_ALL=false
SCRAPE_SCROLL_PAGES=0
SCRAPE_SCROLL_DELAY_MS=1200
# How long to wait for the Marketplace feed to render before failing discovery.
SCRAPE_FEED_SELECTOR_TIMEOUT_MS=60000
SCRAPE_GOTO_RETRY_COUNT=2
# Optional pacing controls (ms). Keep small for manual runs.
SCRAPE_DELAY_MIN_MS=3000
SCRAPE_DELAY_MAX_MS=7000
DB_RETRY_COUNT=3
DB_RETRY_BASE_MS=1500
DB_BATCH_SIZE=25
DB_LOG_CHANGES=false
DB_LOG_CHANGE_LIMIT=25

# Discovery enrichment (visit detail pages to pull description for newly discovered items)
PLAYWRIGHT_DISCOVERY_ENRICH_ENABLED=true
PLAYWRIGHT_DISCOVERY_ENRICH_CONCURRENCY=2
PLAYWRIGHT_DISCOVERY_ENRICH_CHUNK_SIZE=20
PLAYWRIGHT_DISCOVERY_ENRICH_BLOCK_IMAGES=true
PLAYWRIGHT_DISCOVERY_FEED_BLOCK_IMAGES=true

# Discovery filtering (skip obvious accessories/noise)
PLAYWRIGHT_DISCOVERY_MIN_PRICE_PHP=5000
PLAYWRIGHT_DISCOVERY_EXCLUDE_KEYWORDS=charger,case,lcd,battery,spigen,magfit,tempered,screen,cable,adapter,airpods,ps4
# When true, drop listings that don't mention a specific iPhone model (ex: iPhone 11/12/13/14/15/etc).
PLAYWRIGHT_DISCOVERY_REQUIRE_IPHONE_MODEL=false

# Legacy / optional (Puppeteer runner)
# PUPPETEER_USE_STEALTH=true
# PLAYWRIGHT_USE_STEALTH=false
# PLAYWRIGHT_DETAIL_DESCRIPTION_ENABLED=true
# PLAYWRIGHT_DETAIL_DESCRIPTION_MAX_PAGES=8
# PLAYWRIGHT_NOT_SEEN_DEACTIVATE_RUNS=3
PLAYWRIGHT_WATCHLIST_RECHECK_LIMIT=8
PLAYWRIGHT_WATCHLIST_RECHECK_CONCURRENCY=1
PLAYWRIGHT_WATCHLIST_CHUNK_SIZE=20
PLAYWRIGHT_MONITOR_BLOCK_IMAGES=true
PLAYWRIGHT_MONITOR_WAIT_FOR_NETWORKIDLE=false
# Optional explicit executable paths (Windows):
# PUPPETEER_CHROMIUM_EXECUTABLE=C:\Users\you\AppData\Local\ms-playwright\chromium-1179\chrome-win\chrome.exe
# PUPPETEER_CHROME_EXECUTABLE=C:\Program Files\Google\Chrome\Application\chrome.exe
# PUPPETEER_MSEDGE_EXECUTABLE=C:\Program Files (x86)\Microsoft\Edge\Application\msedge.exe
